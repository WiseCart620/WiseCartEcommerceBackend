
# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
DB_URL=jdbc:mysql://mysql:3306/wisecart_dev?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=<your-database-password>
MYSQL_ROOT_PASSWORD=<same-as-DB_PASSWORD>


# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=<your-jwt-secret>


# ------------------------------------------------------------
# ADMIN ACCOUNT
# (Used to seed the default admin user on first startup)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@wisecart.ph
ADMIN_PASSWORD=<your-admin-password>
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User


# ------------------------------------------------------------
# MAIL (Gmail App Password)
# Generate at: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
EMAIL_USERNAME=sales@wisecart.ph
EMAIL_PASSWORD=<your-gmail-app-password>


# ------------------------------------------------------------
# FILE UPLOAD
# ------------------------------------------------------------
UPLOAD_DIR=./uploads-dev


# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
PORT=8080


# ------------------------------------------------------------
# FLASH EXPRESS
# Sandbox:    https://open-api-tra.flashexpress.ph
# Production: https://open-api.flashexpress.ph
# ------------------------------------------------------------
FLASH_EXPRESS_MCH_ID=<your-merchant-id>
FLASH_EXPRESS_SECRET_KEY=<your-secret-key>
FLASH_EXPRESS_WAREHOUSE_NO=
FLASH_EXPRESS_BASE_URL=https://open-api-tra.flashexpress.ph

# Pickup / shipper address
FLASH_EXPRESS_SRC_NAME=<your-store-name>
FLASH_EXPRESS_SRC_PHONE=<your-phone-number>
FLASH_EXPRESS_SRC_PROVINCE=Metro Manila
FLASH_EXPRESS_SRC_CITY=Muntinlupa City
FLASH_EXPRESS_SRC_POSTAL=1634
FLASH_EXPRESS_SRC_DETAIL_ADDRESS=<your-full-pickup-address>


# ------------------------------------------------------------
# DOCKER  (CI/CD + docker-compose)
# ------------------------------------------------------------
DOCKER_USERNAME=<your-dockerhub-username>


# ------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins
# ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://wisecartfrontend.vercel.app,http://localhost:3000,http://localhost:5173


# ------------------------------------------------------------
# CONTACT FORM
# ------------------------------------------------------------
CONTACT_RECIPIENT_EMAIL=sales@wisecart.ph